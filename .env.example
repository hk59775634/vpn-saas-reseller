# =============================================================================
# B 站分销商站（vpn-saas-reseller）— 环境变量模板
# 复制为 .env 后填写：`cp .env.example .env && php artisan key:generate`
# =============================================================================

APP_NAME="VPN Reseller"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# B 站公网根 URL（用户前台、易支付跳转、回调路径均依赖此项）
APP_URL=https://b.example.com

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# 数据库（当前运行环境为 SQLite 单文件；生产可改为 mysql/pgsql）
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_DATABASE 留空则使用 database/database.sqlite
# DB_DATABASE=/var/www/vpn-saas-reseller/database/database.sqlite

# 若使用 MySQL，示例：
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=vpn_b
# DB_USERNAME=vpn_b
# DB_PASSWORD=change_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# 仅在 .env 中显式填写 REDIS_URL 或 REDIS_HOST 时，应用启动会 PING Redis；成功则 cache/session/queue 使用 Redis，失败则回退 database。不填写则完全不启用 Redis 栈，按上方 CACHE_STORE / SESSION_DRIVER / QUEUE_CONNECTION
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# 对接 A 站（控制面）— 必填：URL + 服务端调用用的分销商 API Key
# -----------------------------------------------------------------------------
VPN_A_URL=https://a.example.com
VPN_A_CACHE_TTL=300
# 本地产品归属等回退用；SSL 登录名后缀以 A 站 GET /api/v1/reseller/me 为准
VPN_A_RESELLER_ID=1
VPN_A_RESELLER_API_KEY=rk_replace_with_key_from_a_site

# 注册/开通默认区域（可选）
# VPN_DEFAULT_REGION=
# 用户端展示的 SSL VPN 网关提示（可选）
# VPN_A_SSLVPN_GATEWAY=vpn.example.com

# -----------------------------------------------------------------------------
# 分销商后台登录（仅 .env，不存数据库）— 用户名 + bcrypt 密码哈希
# 生成哈希：php -r "echo password_hash('YourPassword', PASSWORD_BCRYPT);"
# -----------------------------------------------------------------------------
RESELLER_ADMIN_USERNAME=admin
RESELLER_ADMIN_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# 用户端彩虹易支付（见 config/epay.php；完整配置可在分销商后台「支付设置」写入数据库）
# -----------------------------------------------------------------------------
EPAY_ENABLED=false
EPAY_GATEWAY=https://pay.example.com
EPAY_PID=
EPAY_KEY=
# EPAY_NOTIFY_URL=
# EPAY_RETURN_URL=
EPAY_ALLOW_SIMULATED_PAYMENT=false
